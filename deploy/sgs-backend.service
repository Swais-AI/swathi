[Unit]
Description=SGS FastAPI backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/swathi/backend
EnvironmentFile=/home/ubuntu/swathi/backend/.env
ExecStart=/home/ubuntu/swathi/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8004
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
